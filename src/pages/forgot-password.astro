---
export const prerender = false;
import Layout from "../layouts/Layout.astro";
---

<Layout title="Forgot password">
  <section
    class="h-screen bg-black w-full flex justify-center items-center px-4"
  >
    <form
      action="/api/auth/forgot-password"
      method="post"
      class="max-w-sm w-full mx-auto bg-base-200 p-10 flex flex-col gap-4"
    >
      <h1 class="text-center font-bold text-4xl uppercase">Forgot Password</h1>
      <div class="flex flex-col gap-4">
        <label class="input input-bordered flex items-center gap-2">
          Email
          <input
            id="email"
            name="email"
            type="email"
            class="grow"
            required
            placeholder="goggins@gmail.com"
          />
        </label>
        <div class="flex flex-col gap-1">
          <button type="submit" class="btn btn-primary btn-sm mx-auto"
            >ENTER</button
          >
          <div class="flex flex-col gap-1">
            <h1 class="flex gap-1 text-sm mx-auto">
              <span>Already have an account?</span><a
                href="/login"
                class="w-fit link link-primary">Log in here</a
              >
            </h1>
          </div>
        </div>
      </div>
    </form>
  </section>
</Layout>
